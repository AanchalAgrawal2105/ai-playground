# =============================================================================
# Airflow Intelligence Agent — Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------
# PostgreSQL connection string to your Airflow metadata database.
AIRFLOW_DB_URL=postgresql://airflow_user:your_password@your-rds-host.region.rds.amazonaws.com:5432/airflow

# Optional: Granular connection details (used by some deployment scripts)
AIRFLOW_DB_HOST=your-rds-host.region.rds.amazonaws.com
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=your_password

# ---------------------------------------------------------------------------
# AWS Bedrock (REQUIRED)
# ---------------------------------------------------------------------------
# Region where your Bedrock model is deployed.
AWS_REGION=eu-west-1

# Model ID — Claude Sonnet on Bedrock.
MODEL_ID=model-name

# Credentials — leave blank if using IAM roles / instance profiles.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---------------------------------------------------------------------------
# Slack Integration (REQUIRED configuration, optional token)
# ---------------------------------------------------------------------------
# Bot token from https://api.slack.com/apps → OAuth & Permissions.
# Required scopes: chat:write, chat:write.customize
# Leave blank if not using Slack, but other Slack vars still required.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#airflow-alerts
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_USERNAME=Airflow Intelligence Agent
SLACK_EMOJI=:robot_face:

# ---------------------------------------------------------------------------
# Agent Behavior (REQUIRED)
# ---------------------------------------------------------------------------
# Temperature: 0.0 = deterministic, 1.0 = creative
# Recommended: 0.3 for analysis tasks
AGENT_TEMPERATURE=0.3

# Max tokens per response: 100-8192
# Recommended: 4096
AGENT_MAX_TOKENS=4096

# Max reasoning iterations: 5-30
# Recommended: 10 for regular, 20 for comprehensive reports
AGENT_MAX_ITERATIONS=10

# ---------------------------------------------------------------------------
# Monitoring Configuration (REQUIRED)
# ---------------------------------------------------------------------------
# Hours to look back for failure detection
WINDOW_HOURS=24

# Days of historical data for baseline calculation
BASELINE_DAYS=14

# Minimum number of historical runs required for baseline
MIN_HISTORY=10

# Anomaly detection multiplier (duration > baseline * multiplier = anomaly)
ANOMALY_MULTIPLIER=1.5

# Days before DAG considered stale (not run recently)
STALE_DAG_THRESHOLD_DAYS=10

# ---------------------------------------------------------------------------
# Performance Configuration (REQUIRED)
# ---------------------------------------------------------------------------
# Database query timeout in seconds
QUERY_TIMEOUT=30

# Maximum results per query
MAX_RESULTS=1000
